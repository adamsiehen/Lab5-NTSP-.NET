<Window x:Class="Lab5.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lab5 NTSP - WPF + IPC" Height="760" Width="1200"
        MinHeight="600" MinWidth="900"
        SizeChanged="Window_SizeChanged">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderThickness="1" BorderBrush="#FFBDBDBD" Padding="8" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Tryb:"/>
                <ComboBox x:Name="EngineModeCombo" Grid.Column="1" SelectedIndex="0">
                    <ComboBoxItem Content="TPL"/>
                    <ComboBoxItem Content="ThreadPool"/>
                </ComboBox>

                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Wątki/Zadania:"/>
                <TextBox x:Name="WorkersText" Grid.Column="4" Text="4"/>

                <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="Miasta:"/>
                <TextBox x:Name="CitiesText" Grid.Column="7" Text="120"/>

                <TextBlock Grid.Column="9" VerticalAlignment="Center" Text="PMX [s]:"/>
                <TextBox x:Name="PmxSecondsText" Grid.Column="10" Text="2"/>

                <TextBlock Grid.Column="12" VerticalAlignment="Center" Text="3-opt [s]:"/>
                <TextBox x:Name="OptSecondsText" Grid.Column="13" Text="2"/>

                <TextBlock Grid.Column="15" VerticalAlignment="Center" Text="Epoki:"/>
                <TextBox x:Name="EpochsText" Grid.Column="16" Text="5"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="StartButton" Grid.Column="0" Padding="14,6" Margin="0,0,8,0" Click="StartButton_Click">Start</Button>
            <Button x:Name="PauseResumeButton" Grid.Column="1" Padding="14,6" Margin="0,0,8,0" IsEnabled="False" Click="PauseResumeButton_Click">Pauza</Button>
            <Button x:Name="StopButton" Grid.Column="2" Padding="14,6" Margin="0,0,8,0" IsEnabled="False" Click="StopButton_Click">Stop</Button>
            <Button x:Name="CloseButton" Grid.Column="3" Padding="14,6" IsEnabled="False" Click="CloseButton_Click">Zamknij</Button>

            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="Faza: " FontWeight="SemiBold"/>
                <TextBlock x:Name="PhaseValue" Width="80" Text="-"/>
                <TextBlock Text="Epoka: " FontWeight="SemiBold"/>
                <TextBlock x:Name="EpochValue" Width="50" Text="0"/>
                <TextBlock Text="Instancje: " FontWeight="SemiBold"/>
                <TextBlock x:Name="ProcessedValue" Width="120" Text="0"/>
                <TextBlock Text="Best: " FontWeight="SemiBold"/>
                <TextBlock x:Name="BestValue" Width="140" Text="-"/>
                <TextBlock Text="Wątek: " FontWeight="SemiBold"/>
                <TextBlock x:Name="ThreadValue" Width="60" Text="-"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" BorderThickness="1" BorderBrush="#FFBDBDBD" CornerRadius="6" Padding="6">
            <Canvas x:Name="TourCanvas" Background="White"/>
        </Border>
    </Grid>
</Window>
